<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{{ title }} · {{ kicker }} · Pratik Sengupta</title>
<meta name="description" content="{{ tagline }}">
<meta name="theme-color" content="#f5f5f3">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/v2/assets/v2.css">
<link rel="stylesheet" href="/v2/assets/case-v2.css">
</head>
<body class="case-v2">

<nav class="v-nav">
  <span class="v-mark">P. <em>Sengupta</em></span>
  <ul>
    <li><a href="/v2/#work">Work</a></li>
    <li><a href="/v2/#about">About</a></li>
    <li><a href="/v2/#contact">Contact</a></li>
  </ul>
</nav>

<header class="cv-mast">
  <a class="cv-back" href="/v2/">&larr; Index</a>
  <div class="cv-eyebrow"><span class="terra">{{ roman }}</span> {{ kicker }} &middot; the {{ kicker_lower }}</div>
</header>

<article class="cv-body">

  <h1 class="cv-title">{{ title | safe }}.</h1>
  <p class="cv-deck">{{ deck | safe }}</p>
  <div class="cv-frame">{{ frame }}</div>

  <figure class="cv-hero">
    <div class="cv-plate">
      <div class="cv-plate-cap">Hero plate &middot; image forthcoming</div>
    </div>
    <figcaption>{{ hero_caption }}</figcaption>
  </figure>

  <section class="cv-facts">
    {% for f in facts %}
    <div class="cv-fact">
      <div class="cv-fact-k">{{ f.key }}</div>
      <div class="cv-fact-v">{{ f.value | safe }}</div>
    </div>
    {% endfor %}
  </section>

  {% for ch in chapters %}
  <section class="cv-chap">
    <div class="cv-chap-num">{{ ch.num }}</div>
    <h2 class="cv-chap-lead">{{ ch.lead | safe }}</h2>
    <div class="cv-chap-body">
      {{ ch.body | md | safe }}
      {% if ch.pullquote %}
      <blockquote class="cv-pull">{{ ch.pullquote | safe }}</blockquote>
      {% endif %}
    </div>
  </section>
  {% endfor %}

  <section class="cv-credits">
    {% for c in credits %}
    <div class="cv-cred">
      <div class="cv-cred-k">{{ c.key }}</div>
      <div class="cv-cred-v">{{ c.value | safe }}</div>
    </div>
    {% endfor %}
  </section>

  <nav class="cv-next">
    {% if next_slug %}
    <a class="cv-next-link" href="/v2/case/{{ next_slug }}/">
      <div class="cv-next-k">Next operation</div>
      <div class="cv-next-v">{{ next_title }} &rsaquo;</div>
    </a>
    {% endif %}
    <a class="cv-next-link cv-next-alt" href="/v2/#work">
      <div class="cv-next-k">Or</div>
      <div class="cv-next-v">All selected work &rsaquo;</div>
    </a>
  </nav>

</article>

<footer class="v-foot">
  <span>&copy; psg &nbsp;·&nbsp; MMXXVI</span>
  <span class="v-foot-sig">Integration <span class="chev">&rsaquo;</span> Summation</span>
  <span><a href="/v2/">Index &rsaquo;</a></span>
</footer>

<script src="https://unpkg.com/lenis@1.1.18/dist/lenis.min.js"></script>
<script src="/v2/assets/v2.js"></script>
</body>
</html>
