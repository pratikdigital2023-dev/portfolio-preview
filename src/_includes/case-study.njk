<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{{ title }} · Case Study · Pratik Sengupta</title>
<meta name="description" content="{{ tagline }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/case-study.css">
</head>
<body>

<a class="return" href="/">&larr; Return to portfolio</a>
<div class="grain" aria-hidden="true"></div>

<header class="cs-mast wrap">
  <div class="cs-meta">
    <div class="sec-label"><span class="num">{{ case_num }}</span>Selected Work</div>
    <div class="cs-frame">{{ frame }}</div>
  </div>
  <h1 class="cs-title">{{ title | safe }}.</h1>
  <p class="cs-deck">{{ deck | safe }}</p>
</header>

<figure class="cs-hero">
  {% if hero_image %}
    <img src="{{ hero_image }}" alt="{{ hero_caption }}" style="width:100%;display:block;">
  {% else %}
    <div class="ph ph-16x9">
      <div class="ph-caption">Hero image forthcoming &middot; June 2026</div>
    </div>
  {% endif %}
  <figcaption class="cs-cap">{{ hero_caption }}</figcaption>
</figure>

{% if facts and facts.length %}
<section class="cs-facts wrap">
  {% for f in facts %}
  <div class="fact">
    <div class="fact-k">{{ f.key }}</div>
    <div class="fact-v">{{ f.value | safe }}</div>
  </div>
  {% endfor %}
</section>
{% endif %}

{% for ch in chapters %}
<section class="cs-chap wrap">
  <div class="chap-num">{{ ch.num }}</div>
  <div class="chap-grid">
    <div class="chap-lead">{{ ch.lead | safe }}</div>
    <div class="chap-body">
      {{ ch.body | md | safe }}
      {% if ch.pullquote %}
      <blockquote class="cs-pull">
        <span class="pq-mark">&ldquo;</span>{{ ch.pullquote | safe }}<span class="pq-mark">&rdquo;</span>
      </blockquote>
      {% endif %}
    </div>
  </div>
</section>
{% endfor %}

{% if credits and credits.length %}
<section class="cs-credits wrap">
  <div class="cr-grid">
    {% for c in credits %}
    <div class="cr-col">
      <div class="cr-k">{{ c.key }}</div>
      <div class="cr-v">{{ c.value | safe }}</div>
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

<nav class="cs-next wrap">
  {% set nextCase = null %}
  {% for c in collections.caseStudies %}
    {% if c.data.order == (order + 1) %}
      {% set nextCase = c %}
    {% endif %}
  {% endfor %}
  {% if not nextCase %}
    {% set nextCase = collections.caseStudies[0] %}
  {% endif %}
  {% if nextCase.data.slug != slug %}
  <a class="next-link" href="/case/{{ nextCase.data.slug }}/">
    <div class="next-k">Next case study</div>
    <div class="next-v">{{ nextCase.data.title }} <span class="next-arrow">&rarr;</span></div>
  </a>
  {% else %}
  <a class="next-link" href="/#selected-work">
    <div class="next-k">Back to</div>
    <div class="next-v">Selected Work <span class="next-arrow">&rarr;</span></div>
  </a>
  {% endif %}
  <a class="next-link alt" href="/#selected-work">
    <div class="next-k">Or</div>
    <div class="next-v">All selected work <span class="next-arrow">&rarr;</span></div>
  </a>
</nav>

<footer class="cs-foot wrap">
  <div class="colo">
    {{ site.author }} &middot; {{ site.location }} &middot; MMXXVI<br>
  </div>
</footer>

<script src="https://unpkg.com/lenis@1.1.18/dist/lenis.min.js"></script>
<script>
(function(){
  const PR = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const TOUCH = matchMedia('(hover: none) and (pointer: coarse)').matches;
  const root = document.documentElement;
  const body = document.body;

  // Scaffold overlays
  ['grain-coarse','raking-light','aperture','page-transition'].forEach(c => {
    if (!document.querySelector('.' + c)) {
      const el = document.createElement('div'); el.className = c; el.setAttribute('aria-hidden','true'); body.appendChild(el);
    }
  });
  
  // Lenis smooth scroll
  let lenis = null;
  if (!PR && typeof Lenis !== 'undefined') {
    lenis = new Lenis({ duration: 1.4, easing: t => Math.min(1, 1.001 - Math.pow(2, -10*t)), smoothWheel: true, smoothTouch: false, lerp: 0.08 });
    (function raf(t){ lenis.raf(t); requestAnimationFrame(raf); })(0);
  }

  // Scroll progress → raking light y
  function setRake(){
    const max = body.scrollHeight - window.innerHeight;
    const p = max > 0 ? window.scrollY / max : 0;
    root.style.setProperty('--rake-y', (15 + p * 70).toFixed(1));
  }
  window.addEventListener('scroll', setRake, { passive: true }); setRake();

  setTimeout(() => { const rl = document.querySelector('.raking-light'); if (rl) rl.classList.add('on'); }, 900);

  // Aperture
  if (!TOUCH && !PR) {
    const ap = document.querySelector('.aperture');
    let x=-500, y=-500, tx=-500, ty=-500, lx=0, ly=0, lt=performance.now(), vel=0;
    window.addEventListener('pointermove', e => {
      tx=e.clientX; ty=e.clientY;
      const now=performance.now(), dt=Math.max(1,now-lt);
      vel = Math.hypot(e.clientX-lx, e.clientY-ly)/dt;
      lt=now; lx=e.clientX; ly=e.clientY;
      ap.classList.add('on');
    }, {passive:true});
    window.addEventListener('pointerleave', () => ap.classList.remove('on'));
    (function tick(){
      x += (tx-x)*0.18; y += (ty-y)*0.18;
      ap.style.transform = `translate(${x}px, ${y}px)`;
      ap.style.setProperty('--ap-size', Math.max(120, Math.min(220, 160 + vel*60)).toFixed(0));
      vel *= 0.9;
      requestAnimationFrame(tick);
    })();
    const pars = document.querySelectorAll('.chap-body p, .cs-deck');
    (function proximity(){
      pars.forEach(p => {
        const r = p.getBoundingClientRect();
        const d = Math.hypot(r.left+r.width/2-x, r.top+r.height/2-y);
        p.classList.toggle('ap-hit', d < 240);
      });
      requestAnimationFrame(proximity);
    })();
    document.querySelectorAll('a, button').forEach(el => {
      el.addEventListener('mouseenter', () => ap.classList.add('hov'));
      el.addEventListener('mouseleave', () => ap.classList.remove('hov'));
    });
  }

  // Polaroid reveals
  if (!PR) {
    const targets = document.querySelectorAll('.cs-hero, .cs-fig');
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('polaroid-in','go'); io.unobserve(e.target); } });
    }, { threshold: 0.18 });
    targets.forEach(el => { el.classList.add('polaroid-in'); io.observe(el); });
  }

  // Smooth anchor scroll
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const id = a.getAttribute('href').slice(1);
      const el = document.getElementById(id);
      if (!el) return;
      e.preventDefault();
      if (lenis) lenis.scrollTo(el, { offset: -24, duration: 1.5 });
      else window.scrollTo({ top: el.getBoundingClientRect().top + window.scrollY - 20, behavior: 'smooth' });
    });
  });

  // Page transition on internal links
  if (!PR) {
    const overlay = document.querySelector('.page-transition');
    document.querySelectorAll('a[href]').forEach(a => {
      const href = a.getAttribute('href');
      if (!href || href.startsWith('#') || href.startsWith('http') || href.startsWith('mailto:') || href.startsWith('tel:') || a.target === '_blank') return;
      a.addEventListener('click', e => {
        e.preventDefault();
        body.classList.add('page-leaving');
        if (overlay) overlay.classList.add('go');
        setTimeout(() => { window.location.href = href; }, 420);
      });
    });
    window.addEventListener('pageshow', () => {
      body.classList.remove('page-leaving');
      const ov = document.querySelector('.page-transition'); if (ov) ov.classList.remove('go');
    });
  }
})();
</script>
</body>
</html>
